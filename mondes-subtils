  margin-bottom: 40px;
}

.hero-buttons {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
}

.eyebrow {
  color: rgba(255,255,255,0.8);
  letter-spacing: 0.4em;
  font-size: 12px;
  margin-bottom: 30px;
}

.eyebrow.dark {
  color: var(--primary);
}

.intro h2,
.faq-preview h2 {
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.2;
  margin-bottom: 40px;
}

.intro p {
