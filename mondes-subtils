# script.js

```javascript
const elements = document.querySelectorAll('.card')

window.addEventListener('scroll', () => {
  elements.forEach((el) => {
    const top = el.getBoundingClientRect().top

    if (top < window.innerHeight - 100) {
      el.style.opacity = '1'
      el.style.transform = 'translateY(0px)'
    }
  })
})
```

