.grid-3 {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 40px;
}

.card {
  background: white;
  padding: 50px;
  border-radius: 24px;
  transition: 0.5s ease;
  box-shadow: 0 10px 30px rgba(0,0,0,0.03);
