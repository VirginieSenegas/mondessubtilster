  font-weight: 300;
  line-height: 1.4;
  margin-bottom: 30px;
}

.faq-item {
  padding: 40px 0;
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.faq-item h3 {
  margin-bottom: 20px;
  font-weight: 400;
}

.booking-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
  margin-top: 60px;
}

.booking-form input,
.booking-form textarea {
  padding: 22px;
  border-radius: 20px;
  border: none;
  background: rgba(214,215,221,0.2);
  font-family: inherit;
}

.form-message {
  margin-top: 30px;
  color: #777;
  font-size: 14px;
}

.footer {
  padding: 80px 0;
  border-top: 1px solid rgba(0,0,0,0.08);
  background: white;
}

.footer-grid {
  display: flex;
  justify-content: space-between;
  gap: 40px;
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.footer-links a {
  text-decoration: none;
  color: #666;
}

.fade-in {
  animation: fadeIn 1.2s ease forwards;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes breathe {
  0%,100% {
    transform: scale(1) rotate(0deg);
  }

  50% {
    transform: scale(1.02) rotate(1deg);
  }
}

@media (max-width: 900px) {

  nav {
    gap: 20px;
  }

  .grid-3 {
    grid-template-columns: 1fr;
  }

  .footer-grid {
    flex-direction: column;
  }

}

@media (max-width: 700px) {

  .navbar {
    flex-direction: column;
    gap: 20px;
  }

  nav {
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-buttons {
    flex-direction: column;
  }

  .section {
    padding: 90px 0;
  }

  .card {
    padding: 36px;
  }

}
```

